{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "vite/client",
      "audioworklet"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "paths": {
      "@lib/*": [
        "./lib/*"
      ],
      "@ds1/*": [
        "./projects/ds1-fm-synth/*"
      ],
    }
  },
  "include": [
    "lib/**/*"
  ]
}